# Local docker-compose for autonomous-defense-system base dependencies.
# Copy to deploy/.env (gitignored) and fill the secrets below.

# === Required by docker-compose.yml ===
# MySQL root password. Compose will refuse to start when unset.
# Choose a long random string in non-dev environments.
MYSQL_ROOT_PASSWORD=change-me

# Kafka / event topics (no secrets, override only if needed).
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
EVENT_TOPIC=security.events
STRATEGY_TOPIC=defense.strategies
