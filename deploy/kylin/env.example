# =============================================================================
# Kylin / LoongArch deployment environment template
# =============================================================================
#
# Copy this file to deploy/kylin/.env and edit in place. Never commit .env
# (it is git-ignored) and run `chmod 600 deploy/kylin/.env` after creating
# it so secrets stay private. Real API keys must NOT be checked in.
#
# Layout convention:
#   * Section 1 - service ports (override only if you have port conflicts)
#   * Section 2 - paths (used by start-all.sh / stop-all.sh / check-health.sh)
#   * Section 3 - MCP topology (the spec-required block)
#   * Section 4 - LLM credentials for agent-brain
#   * Section 5 - downstream service URLs (agent-brain -> verifier / actuator)
#   * Section 6 - dashboard-ui Vite vars (also written to dashboard-ui/.env)
#   * Section 7 - audit / logging
#   * Section 8 - CORS allow-lists
#
# All shell-script variables below are read by deploy/kylin/start-all.sh and
# deploy/kylin/stop-all.sh; they default to sensible values when unset.

# =============================================================================
# 1) Service ports
# =============================================================================
DEFENSE_GATEWAY_PORT=8080
AGENT_BRAIN_PORT=8001
FORMAL_VERIFIER_PORT=8002
ACTUATOR_SERVICE_PORT=8081
DASHBOARD_UI_PORT=5173

# =============================================================================
# 2) Paths
# =============================================================================
# Repository root - usually one level up from deploy/kylin/ but you can pin it
# to an absolute path if your start script is invoked from elsewhere (systemd
# etc.). Leave empty to auto-detect.
PROJECT_ROOT=

# Per-service venvs and JARs. The defaults match the standard layout:
#   agent-brain/.venv         (python3.11 -m venv .venv)
#   formal-verifier/.venv     (python3.11 -m venv .venv)
#   defense-gateway/target/*.jar
#   actuator-service/target/*.jar
#   dashboard-ui/node_modules
# Override only if you put binaries in unusual locations.
AGENT_BRAIN_VENV=
FORMAL_VERIFIER_VENV=
DEFENSE_GATEWAY_JAR=
ACTUATOR_SERVICE_JAR=

# Java executable used by the start script. Leave empty to use the one on PATH.
JAVA_BIN=

# Python 3.11+ executable. Leave empty to use the one on PATH.
PYTHON_BIN=

# Node binary. Leave empty to use the one on PATH.
NODE_BIN=
NPM_BIN=

# =============================================================================
# 3) MCP topology  (spec-required)
# =============================================================================
# Master switch. When false, agent-brain bypasses every MCP client and uses
# the compatibility fallback (no topology / no policy / no OS context).
ENABLE_MCP=true

# Per-server mode:
#   local - same-process import of *_service.py  (recommended for Kylin)
#   real  - stdio subprocess of server.py        (requires `pip install -e .[mcp]`)
MCP_TOPOLOGY_MODE=local
MCP_POLICY_MODE=local
MCP_OS_MODE=local

# Optional: directory paths for the three MCP servers.
# IMPORTANT: these are DIRECTORIES, not paths to server.py.
# Agent-brain appends server.py internally.
TOPOLOGY_MCP_SERVER_PATH=
POLICY_MCP_SERVER_PATH=
OS_MCP_SERVER_PATH=

# Optional: when MCP_*_MODE=real, override the python interpreter used to
# spawn the stdio subprocess. Defaults to the agent-brain venv python.
MCP_PYTHON_EXECUTABLE=

# Optional: per-call timeout for MCP requests (seconds).
MCP_REQUEST_TIMEOUT_S=10

# =============================================================================
# 4) Agent-brain LLM (OpenAI-compatible)
# =============================================================================
# IMPORTANT: never commit a real key. Leave AGENT_BRAIN_LLM_API_KEY empty to
# fall back to the in-process MockLLMClient (which is enough to demonstrate
# the full /workflow/run and /ops/chat pipeline offline).
AGENT_BRAIN_LLM_API_KEY=
AGENT_BRAIN_LLM_BASE_URL=https://api.siliconflow.cn/v1
AGENT_BRAIN_LLM_MODEL=Pro/deepseek-ai/DeepSeek-V3.2
AGENT_BRAIN_LLM_TIMEOUT_SECONDS=120

# Compatibility behaviour when downstream dependencies are unreachable:
#   compat - return a degraded happy-path envelope (offline demo only)
#   strict - return failure envelopes (default; required for real integration)
AGENT_BRAIN_FAILURE_MODE=strict

# When agent-brain detects it is running as root / uid=0 / Administrator:
#   refuse  - exit immediately (production default)
#   degrade - keep running but lock LeastPrivilegeExecutor into read-only mode
AGENT_BRAIN_ROOT_POLICY=refuse

# Enable the actuator MCP pre-check gate inside /workflow/run.
# When true, every strategy goes through the same 4 safety checks the
# actuator-mcp-server applies (approval, status, rollback plan, TTL).
ACTUATOR_MCP_GUARD_ENABLED=true

# When prompt-injection or system-config guard fires BLOCK during
# /workflow/run, also override nextAction / actuatorResponse to BLOCKED.
WORKFLOW_GUARD_STRICT=true

# =============================================================================
# 5) Downstream service URLs (agent-brain -> verifier / actuator)
# =============================================================================
FORMAL_VERIFIER_BASE_URL=http://localhost:8002
FORMAL_VERIFIER_TIMEOUT_SECONDS=5
ACTUATOR_SERVICE_BASE_URL=http://localhost:8081
ACTUATOR_SERVICE_TIMEOUT_SECONDS=5

# =============================================================================
# 6) Dashboard-ui (Vite)
# =============================================================================
# These get written into dashboard-ui/.env automatically when you run
# start-all.sh, so changes here propagate to the UI without manual edits.
VITE_AGENT_BRAIN_BASE_URL=http://localhost:8001
VITE_API_BASE_URL=http://localhost:8080
# Actuator-service base for /api/executions and /api/strategies/* calls.
VITE_ACTUATOR_BASE_URL=http://localhost:8081
VITE_USE_MOCK=false

# =============================================================================
# 7) Audit / logging
# =============================================================================
# Where the OPS audit JSONL is written. Defaults to agent-brain/data/.
# In production prefer /var/log/autonomous-defense/ops_audit.jsonl
# (make sure the ops-agent user owns the directory and SELinux contexts
# allow writes).
OPS_AUDIT_LOG_PATH=

# Set to "true" to disable the OPS audit log entirely (testing only).
OPS_AUDIT_LOG_DISABLED=false

# -- Per-request JSON audit-file writer ----------------------------------
# Where /ops/chat and /workflow/run write their consolidated per-request
# JSON snapshot (one file per request, named audit-<requestId>.json).
# Default when unset: <repo_root>/logs/audit/.
# In production prefer /var/log/autonomous-defense/audit/ and chown to
# the ops-agent user.
AUDIT_LOG_DIR=

# Set to "true" to disable the per-request audit-file writer entirely
# (testing only). The auditFile field on responses will be omitted.
AUDIT_LOG_DISABLED=false

# =============================================================================
# 8) CORS allow-lists
# =============================================================================
# Comma-separated origins. Use exact origins in production; never `*`.
AGENT_BRAIN_CORS_ORIGINS=http://localhost:5173
GATEWAY_CORS_ALLOWED_ORIGINS=http://localhost:5173
ACD_ORCHESTRATION_CORS_ALLOWED_ORIGINS=http://localhost:5173

# =============================================================================
# 9) defense-gateway DB / Kafka (only if you actually run the gateway)
# =============================================================================
DB_HOST=localhost
DB_PORT=3307
DB_NAME=autonomous_defense
DB_USER=root
DB_PASSWORD=
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
EVENT_TOPIC=security.events
