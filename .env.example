# autonomous-defense-system — 复制为 .env 后按需修改
#
# =========================
# 1) agent-brain 核心开关
# =========================
# 真实联调默认：strict（关键依赖不可用时返回失败，不做成功形态兜底）。
# 仅在做离线演示且确实希望降级为成功形态时改为 compat。
AGENT_BRAIN_FAILURE_MODE=strict

# CORS 白名单（逗号分隔）；开发默认可包含 dashboard-ui
AGENT_BRAIN_CORS_ORIGINS=http://localhost:5173
GATEWAY_CORS_ALLOWED_ORIGINS=http://localhost:5173
ACD_ORCHESTRATION_CORS_ALLOWED_ORIGINS=http://localhost:5173

# =========================
# 2) MCP（Topology / Policy）
# =========================
# ENABLE_MCP=false：关闭 MCP，全部走本地无拓扑/无策略MCP的基础链路
# ENABLE_MCP=true + local：同进程加载 *_service.py（推荐开发）
# ENABLE_MCP=true + real：stdio 子进程 server.py（需 pip install -e ".[mcp]"）
ENABLE_MCP=true
MCP_TOPOLOGY_MODE=local
MCP_POLICY_MODE=local

# 可选：自定义 MCP Server 目录
# TOPOLOGY_MCP_SERVER_PATH=
# POLICY_MCP_SERVER_PATH=
# MCP_PYTHON_EXECUTABLE=
# MCP_REQUEST_TIMEOUT_S=10

# =========================
# 3) LLM（OpenAI 兼容 /chat/completions）
# =========================
# 不配置 Key 时自动使用 MockLLMClient（可完整跑通流程）
AGENT_BRAIN_LLM_API_KEY=
AGENT_BRAIN_LLM_BASE_URL=https://api.siliconflow.cn/v1
AGENT_BRAIN_LLM_MODEL=Pro/deepseek-ai/DeepSeek-V3.2
AGENT_BRAIN_LLM_TIMEOUT_SECONDS=120
# agent-brain 下游依赖地址（可选；默认 8002 / 8081）
FORMAL_VERIFIER_BASE_URL=http://localhost:8002
FORMAL_VERIFIER_TIMEOUT_SECONDS=5
ACTUATOR_SERVICE_BASE_URL=http://localhost:8081
ACTUATOR_SERVICE_TIMEOUT_SECONDS=5
# 也可改用 OPENAI_API_KEY / OPENAI_BASE_URL / OPENAI_MODEL

# =========================
# 4) 前端（dashboard-ui）
# =========================
# defense-gateway 提供 /api/events，actuator-service 提供 /api/executions。
# 前端按服务分基址访问，避免“执行记录请求落到网关”的错路。
VITE_API_BASE_URL=http://localhost:8080
VITE_AGENT_BRAIN_BASE_URL=http://localhost:8001
VITE_AGENT_BRAIN_URL=http://localhost:8001
VITE_ACTUATOR_BASE_URL=http://localhost:8081
# 真实联调默认关闭 mock；只有离线演示时才改为 true
VITE_USE_MOCK=false

# =========================
# 5) actuator-mcp-server（可选；agent-brain 主链路通过 ActuatorMCPGuard 共享其预检规则）
# =========================
# ACTUATOR_BASE_URL=http://localhost:8081
# Enable / disable the actuator MCP pre-check gate inside /workflow/run (default: true)
ACTUATOR_MCP_GUARD_ENABLED=true

# =========================
# 6) /workflow/run 强阻断开关
# =========================
# 当 prompt-injection guard 或 system-config guard 命中 BLOCK 时，
# 不仅记审计，还强制把 nextAction / actuatorResponse 翻成 BLOCKED。
WORKFLOW_GUARD_STRICT=true

# =========================
# 7) agent-brain 启动期高权限检测
# =========================
# 当进程检测到运行身份为 root / uid=0 / Administrator 时：
#   refuse - 启动直接退出（推荐生产/演示）
#   degrade - 允许启动但 LeastPrivilegeExecutor 锁死为只读
AGENT_BRAIN_ROOT_POLICY=refuse
