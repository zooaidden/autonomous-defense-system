# dashboard-ui environment variables (Vite)
#
# All variables are optional - live localhost integration defaults are baked in.

# ---------------------------------------------------------------------------
# Agent-brain API (POST /workflow/run, POST /ops/chat, GET /ops/audit/{id})
# Preferred name. VITE_AGENT_BRAIN_URL is also accepted as an alias.
# ---------------------------------------------------------------------------
VITE_AGENT_BRAIN_BASE_URL=http://localhost:8001

# ---------------------------------------------------------------------------
# Legacy security-event API (Java backend). Optional.
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# Actuator service API (GET /api/executions, POST /api/strategies/execute)
# ---------------------------------------------------------------------------
VITE_ACTUATOR_BASE_URL=http://localhost:8081

# ---------------------------------------------------------------------------
# When true the UI shows mocked OPS chat results / mock event/execution data,
# useful for offline demos. Keep false for real end-to-end integration.
# ---------------------------------------------------------------------------
VITE_USE_MOCK=false
